{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "baseUrl": "./",
    "rootDir": "./src",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "types": ["node", "bun-types"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
